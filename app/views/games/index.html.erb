<h1 class="mb-4">Game Results</h1>

<table class="table table-striped table-bordered table-hover table-sm align-middle">
  <thead class="table-dark">
    <tr>
      <th style="width:12%">Date</th>
      <th>Top 3</th>
      <th>Last Place</th>
      <th style="width:12%">Actions</th>
    </tr>
  </thead>
  <tbody>
  <% @games.each do |game| %>
    <% final_results = game.entrants.sort_by { |e| e.final_position || 999 } %>
    <tr>
      <td><%= game.created_at.strftime("%b %-d, %Y") %></td>
      <td>
        <% if game.entrants.any? { |e| e.final_position } %>
          <ol class="mb-0 ps-3">
            <% final_results.first(3).each do |entrant| %>
              <li><%= link_to entrant.player.display_name, entrant.player %></li>
            <% end %>
          </ol>
        <% elsif game.started %>
          <span class="badge bg-warning text-dark">In Progress</span>
        <% end %>
      </td>
      <td>
        <% if game.entrants.any? { |e| e.final_position } && final_results.size > 3 %>
          <span class="text-danger"><%= link_to final_results.last.player.display_name, final_results.last.player %></span>
        <% end %>
      </td>
      <td>
        <div class="d-flex flex-column gap-1">
          <% if game.started %>
            <%= link_to 'Play', game, class: 'btn btn-sm btn-success' %>
            <%= link_to 'Edit Players', edit_game_path(game), class: 'btn btn-sm btn-outline-secondary' %>
          <% else %>
            <%= link_to 'Details', game, class: 'btn btn-sm btn-outline-primary' %>
          <% end %>
          <%= link_to 'Delete', game, data: { confirm: 'Are you sure?' }, method: :delete, class: 'btn btn-sm btn-outline-danger' %>
        </div>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>

<div class="mt-3"><%= will_paginate @games, renderer: Bootstrap5Renderer %></div>
<p class="text-muted small"><%= page_entries_info(@games).html_safe %></p>

<%= link_to 'New Game', new_game_path, class: 'btn btn-primary mt-2 text-white' %>
